<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingBottom="110dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- HEADER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <ImageView
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@drawable/logo"/>

                    <TextView
                        android:layout_width="1dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:text="FutureSuShi"
                        android:textColor="#FFFFFF"
                        android:textSize="25sp"
                        android:textStyle="bold"/>
                    <!-- LOGIN -->

                    <LinearLayout
                        android:id="@+id/btnLoginHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:background="@drawable/bg_login"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="15dp">


                        <!-- TEXT -->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="8dp"
                            android:text="Đăng nhập"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/menuBtn"
                        android:layout_width="60dp"
                        android:layout_height="35dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="#FFFFFF" />


                </LinearLayout>

                <!-- BANNER -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="500dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/banner_sushi"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#8A000000"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TƯƠI NGON&#10;TỪNG NGÀY"
                            android:textColor="#FFFFFF"
                            android:textSize="42sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="TRỌN VỊ NHẬT"
                            android:textColor="#FF1E1E"
                            android:textSize="44sp"
                            android:textStyle="bold"/>

                        <View
                            android:layout_width="90dp"
                            android:layout_height="4dp"
                            android:layout_marginTop="18dp"
                            android:background="#FF1E1E"/>

                        <TextView
                            android:layout_width="290dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:lineSpacingExtra="5dp"
                            android:text="FutureSuShi cam kết mang đến trải nghiệm ẩm thực Nhật Bản với nguyên liệu tươi ngon mỗi ngày."
                            android:textColor="#D6D6D6"
                            android:textSize="18sp"/>

                    </LinearLayout>

                </FrameLayout>

                <!-- INFO BOX -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_info"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <!-- ITEM 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_fresh"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="NGUYÊN LIỆU"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingTop="8dp"
                            android:text="Tươi ngon\nmỗi ngày"
                            android:textColor="#CFCFCF"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <!-- ITEM 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_chef"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="ĐỘI NGŨ BẾP"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingTop="8dp"
                            android:text="Chuyên nghiệp\nvà tận tâm"
                            android:textColor="#CFCFCF"
                            android:textSize="12sp"/>

                    </LinearLayout>

                    <!-- ITEM 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_japan"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="CHUẨN NHẬT"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingTop="8dp"
                            android:text="Tinh hoa\nẩm thực Nhật"
                            android:textColor="#CFCFCF"
                            android:textSize="12sp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- VOUCHER -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="8dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- IMAGE -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/voucher"
                            android:scaleType="centerCrop"/>

                        <!-- OVERLAY -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#70000000"/>

                        <!-- CONTENT -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ƯU ĐÃI ĐẶC BIỆT"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="260dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Nhận voucher giảm giá hấp dẫn khi đặt món tại FutureSuShi."
                                android:textColor="#E0E0E0"
                                android:textSize="15sp"/>

                            <Button
                                android:id="@+id/btnVoucher"
                                android:layout_width="160dp"
                                android:layout_height="52dp"
                                android:layout_marginTop="24dp"
                                android:text="XEM ƯU ĐÃI"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#E50914"/>

                        </LinearLayout>

                    </FrameLayout>

                </androidx.cardview.widget.CardView>

                <!-- FOOTER -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="30dp"
                    android:text="FUTURESUSHI - TRẢI NGHIỆM ẨM THỰC NHẬT BẢN ĐÍCH THỰC"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- BOTTOM MENU -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="82dp"
            android:layout_gravity="bottom"
            android:layout_margin="12dp"
            app:cardBackgroundColor="#101010"
            app:cardCornerRadius="35dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- HOME -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_home"
                        app:tint="#FF1E1E"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trang chủ"
                        android:textColor="#FF1E1E"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- DAT BAN -->
                <LinearLayout
                    android:id="@+id/btnBooking"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đặt bàn"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- FLOATING QR -->
                <LinearLayout
                    android:id="@+id/btnScanQR"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="55dp"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_qr_button"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:elevation="10dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_qr"
                            app:tint="#FFFFFF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SCAN"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- REVIEW -->

                <LinearLayout
                    android:id="@+id/btnReview"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_star"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đánh giá"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- ACCOUNT -->
                <LinearLayout
                    android:id="@+id/idAccount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_user"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tài khoản"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- NAVIGATION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#0F0F0F"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#E50914"
        app:menu="@menu/drawer_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>
