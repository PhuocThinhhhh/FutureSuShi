<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- HEADER -->

    <LinearLayout
        android:id="@+id/topHeader"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp">

        <!-- BACK -->

        <ImageView
            android:id="@+id/btnBackBooking"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            app:tint="#FFFFFF"/>

        <!-- LOGO -->

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="14dp"
            android:src="@drawable/logo"/>

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:text="ĐẶT BÀN"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- CONTENT -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topHeader"
        android:paddingBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- BANNER -->

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="10dp"
                android:scaleType="centerCrop"
                android:src="@drawable/booking_banner"/>

            <!-- TITLE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:text="Thông tin đặt bàn"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <!-- NAME -->

            <EditText
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_input"
                android:hint="Tên khách hàng"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E"
                android:paddingHorizontal="18dp"/>

            <!-- PHONE -->

            <EditText
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input"
                android:hint="Số điện thoại"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E"
                android:paddingHorizontal="18dp"
                android:inputType="phone"/>

            <!-- PEOPLE -->

            <EditText
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input"
                android:hint="Số lượng người"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E"
                android:paddingHorizontal="18dp"
                android:inputType="number"/>

            <!-- TIME TITLE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:text="Chọn khung giờ"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- TIME CHIP -->

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <!-- ACTIVE -->

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_category_active"
                        android:gravity="center"
                        android:text="17:00"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>

                    <!-- NORMAL -->

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_category"
                        android:gravity="center"
                        android:text="18:00"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_category"
                        android:gravity="center"
                        android:text="19:00"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_category"
                        android:gravity="center"
                        android:text="20:00"
                        android:textColor="#FFFFFF"/>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- NOTICE -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="26dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <!-- ICON -->

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_info"
                        app:tint="#E50914"/>

                    <!-- TEXT -->

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="14dp"
                        android:text="Quản lý sẽ xác nhận bàn phù hợp cho bạn. Nếu quá 30 phút chưa nhận bàn, yêu cầu sẽ tự động hủy."
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- BUTTON -->

            <Button
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="#E50914"
                android:text="GỬI YÊU CẦU ĐẶT BÀN"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>