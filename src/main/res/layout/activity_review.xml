<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- HEADER -->

    <LinearLayout
        android:id="@+id/topHeader"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp">

        <!-- BACK -->

        <ImageView
            android:id="@+id/btnBackReview"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            app:tint="#FFFFFF"/>

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:text="ĐÁNH GIÁ"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- CONTENT -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- TITLE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trải nghiệm FutureSuShi"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chia sẻ cảm nhận của bạn về món ăn và dịch vụ."
                android:textColor="#BDBDBD"
                android:textSize="14sp"/>

            <!-- KHONG GIAN -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <!-- TEXT -->

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Không gian"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <!-- STARS -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/star1Space"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star2Space"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star3Space"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star4Space"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_empty"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star5Space"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_empty"
                            app:tint="#FFD54F"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- PHUC VU -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <!-- TEXT -->

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phục vụ"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <!-- STARS -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/star1Service"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star2Service"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star3Service"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star4Service"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star5Service"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_empty"
                            app:tint="#FFD54F"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- MON AN -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <!-- TEXT -->

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Món ăn"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <!-- STARS -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/star1Food"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star2Food"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star3Food"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star4Food"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                        <ImageView
                            android:id="@+id/star5Food"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_star_fill"
                            app:tint="#FFD54F"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- FEEDBACK -->

            <EditText
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Chia sẻ cảm nhận của bạn..."
                android:padding="18dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#9E9E9E"/>

            <!-- IMAGE -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="#111111"
                app:cardCornerRadius="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_image"
                        app:tint="#E50914"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Thêm hình ảnh"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- BUTTON -->

            <Button
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#E50914"
                android:text="GỬI ĐÁNH GIÁ"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>